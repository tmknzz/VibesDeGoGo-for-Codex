{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'repo=$(git rev-parse --show-toplevel 2>/dev/null || pwd); skill=\"${VDGG_CODEX_SKILL_DIR:-$repo/.agents/skills/vibesdegogo}\"; [ -f \"$skill/scripts/vdgg-hook-pretool.sh\" ] || skill=\"$HOME/.agents/skills/vibesdegogo\"; bash \"$skill/scripts/vdgg-hook-pretool.sh\"'",
            "timeout": 5,
            "statusMessage": "Checking VibesDeGoGo! workflow state"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'repo=$(git rev-parse --show-toplevel 2>/dev/null || pwd); skill=\"${VDGG_CODEX_SKILL_DIR:-$repo/.agents/skills/vibesdegogo}\"; [ -f \"$skill/scripts/vdgg-hook-posttool.sh\" ] || skill=\"$HOME/.agents/skills/vibesdegogo\"; bash \"$skill/scripts/vdgg-hook-posttool.sh\"'",
            "timeout": 5,
            "statusMessage": "Recording VibesDeGoGo! tool result"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'repo=$(git rev-parse --show-toplevel 2>/dev/null || pwd); skill=\"${VDGG_CODEX_SKILL_DIR:-$repo/.agents/skills/vibesdegogo}\"; [ -f \"$skill/scripts/vdgg-hook-stop.sh\" ] || skill=\"$HOME/.agents/skills/vibesdegogo\"; bash \"$skill/scripts/vdgg-hook-stop.sh\"'",
            "timeout": 5
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'VDGG_CODEX_SKILL_DIR=\"${VDGG_CODEX_SKILL_DIR:-$HOME/.agents/skills/vibesdegogo}\"; bash \"$VDGG_CODEX_SKILL_DIR/scripts/vdgg-hook-userprompt.sh\"'",
            "timeout": 5,
            "statusMessage": "Checking VibesDeGoGo! default workflow"
          }
        ]
      }
    ]
  }
}
